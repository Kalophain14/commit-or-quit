# ─── OS FILES ───────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── EDITOR & IDE ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.helix/

# ─── LOGS & TEMP ────────────────────────────────────────
*.log
*.tmp
*.temp
