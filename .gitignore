# ─── ENVIRONMENT & SECRETS ──────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12
secrets/
.secrets

# ─── DOTFILE SPECIFIC ───────────────────────────────────
# Sensitive shell history
.bash_history
.zsh_history
.fish_history

# Private configs (keep these local only)
.ssh/
.gnupg/
.netrc
.authinfo

# Local machine overrides (not for sharing)
*.local
.localrc
local.sh

# Backup files created by editors/tools
*.bak
*.orig
*.backup

# ─── NODE ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ─── PYTHON ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
dist/
build/
*.egg-info/

# ─── COMPILED / BINARY ──────────────────────────────────
*.o
*.out
*.class
*.exe
*.dll
*.so
